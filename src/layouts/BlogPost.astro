---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-gray-50 text-gray-800 antialiased">
		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-white/70 backdrop-blur-xl border-b border-gray-200/50">
			<div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/" class="text-xl font-black tracking-tight text-gray-900">Smart<span class="text-blue-600">Home</span>Made</a>
				<div class="flex items-center gap-6 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-gray-900 transition">Home</a>
					<a href="/blog" class="hover:text-gray-900 transition">Articles</a>
					<a href="/about" class="hover:text-gray-900 transition">About</a>
				</div>
			</div>
		</nav>

		<main class="max-w-3xl mx-auto px-6 py-12">
			<article>
				<header class="mb-10">
					<p class="text-sm text-blue-600 font-medium uppercase tracking-wider mb-3">
						<FormattedDate date={pubDate} />
						{updatedDate && <span class="text-gray-400 ml-2">· Updated <FormattedDate date={updatedDate} /></span>}
					</p>
					<h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-4">{title}</h1>
					<p class="text-lg text-gray-500 leading-relaxed">{description}</p>
					<div class="mt-6 h-px bg-gradient-to-r from-blue-600 via-blue-300 to-transparent"></div>
				</header>
				<div class="prose max-w-none">
					<slot />
				</div>
			</article>
		</main>

		<footer class="bg-gray-900 text-gray-400 mt-20">
			<div class="max-w-6xl mx-auto px-6 py-12 text-center">
				<p class="text-white font-bold text-lg mb-1">Smart<span class="text-blue-400">Home</span>Made</p>
				<p class="text-sm">Honest smart home reviews and guides.</p>
				<p class="text-xs mt-4 text-gray-600">&copy; 2026 SmartHomeMade. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
