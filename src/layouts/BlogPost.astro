---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;

// Estimate read time (~200 words/min)
const readTimeMin = 6;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
	"publisher": {
		"@type": "Organization",
		"name": SITE_TITLE,
		"url": "https://smarthomemade.com"
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.href
	}
});
---

<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`${title} — ${SITE_TITLE}`} description={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style>body { font-family: 'Inter', system-ui, sans-serif; }</style>

		<!-- Extra SEO -->
		<meta property="og:type" content="article" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Schema.org Article -->
		<script type="application/ld+json" set:html={jsonLd} />
	</head>
	<body class="bg-white text-gray-900 antialiased">

		<!-- Top accent -->
		<div class="h-1 bg-gradient-to-r from-blue-600 via-violet-500 to-cyan-500"></div>

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100/80 shadow-sm">
			<div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
				<a href="/" class="text-xl font-black tracking-tight">Smart<span class="text-blue-600">Home</span>Made</a>
				<div class="flex items-center gap-6 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-blue-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="hover:text-blue-600 transition-colors duration-200">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition-colors duration-200">About</a>
				</div>
			</div>
		</nav>

		<main class="max-w-3xl mx-auto px-6 py-12 md:py-16">
			<article>
				<!-- Breadcrumb -->
				<div class="flex items-center gap-2 text-sm text-gray-400 mb-8">
					<a href="/" class="hover:text-blue-600 transition-colors duration-200">Home</a>
					<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
					<a href="/blog" class="hover:text-blue-600 transition-colors duration-200">Articles</a>
					<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
					<span class="text-gray-600 truncate max-w-[200px]">{title}</span>
				</div>

				<header class="mb-10">
					<!-- Meta -->
					<div class="flex flex-wrap items-center gap-3 mb-4">
						<span class="bg-blue-50 text-blue-600 px-3 py-1 rounded-full text-xs font-bold">Guide</span>
						<span class="text-sm text-gray-400">
							<FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="text-sm text-gray-400">
								· Updated <FormattedDate date={updatedDate} />
							</span>
						)}
						<span class="text-sm text-gray-400">· {readTimeMin} min read</span>
					</div>

					<!-- Title -->
					<h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-4">{title}</h1>
					<p class="text-lg md:text-xl text-gray-500 leading-relaxed">{description}</p>

					<!-- Gradient accent line -->
					<div class="mt-8 h-1 w-24 bg-gradient-to-r from-blue-600 via-violet-500 to-cyan-500 rounded-full"></div>
				</header>

				<div class="prose max-w-none">
					<slot />
				</div>

				<!-- Post footer -->
				<div class="mt-16 pt-8 border-t border-gray-100">
					<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
						<div>
							<p class="text-sm text-gray-400">Published on <FormattedDate date={pubDate} /></p>
							{updatedDate && <p class="text-sm text-gray-400">Last updated <FormattedDate date={updatedDate} /></p>}
						</div>
						<a href="/blog" class="inline-flex items-center gap-2 text-blue-600 font-semibold text-sm hover:gap-3 transition-all duration-300">
							<svg class="w-4 h-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
							All Articles
						</a>
					</div>
				</div>
			</article>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-950 text-gray-400 mt-20">
			<div class="max-w-7xl mx-auto px-6 lg:px-10 py-16">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
					<div class="col-span-2 md:col-span-1">
						<a href="/" class="text-xl font-black text-white">Smart<span class="text-blue-400">Home</span>Made</a>
						<p class="text-sm text-gray-500 mt-3 leading-relaxed">Honest smart home reviews and guides.</p>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Content</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">All Articles</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Reviews</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Buying Guides</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Categories</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Smart Plugs</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Voice Assistants</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Lighting</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">About</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/about" class="hover:text-white transition-colors duration-200">About Us</a></li>
							<li><a href={new URL('rss.xml', Astro.site).href} class="hover:text-white transition-colors duration-200">RSS Feed</a></li>
						</ul>
					</div>
				</div>
				<div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
					<p class="text-xs text-gray-600">&copy; 2026 SmartHomeMade. All rights reserved.</p>
					<p class="text-xs text-gray-600">Made with care for smart home enthusiasts.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
