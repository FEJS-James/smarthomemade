---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featured = posts[0];
const rest = posts.slice(1);

const categoryImages: Record<string, string> = {
	'Smart Plugs': 'https://images.unsplash.com/photo-1558002038-1055907df827?w=600&q=80',
	'Lighting': 'https://images.unsplash.com/photo-1565814329452-e1432341e8cf?w=600&q=80',
	'Voice Control': 'https://images.unsplash.com/photo-1543512214-318228f18290?w=600&q=80',
	'Security': 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600&q=80',
	'Climate': 'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=600&q=80',
	'Getting Started': 'https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=600&q=80',
};

const articleImages = [
	'https://images.unsplash.com/photo-1558002038-1055907df827?w=800&q=80',
	'https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=800&q=80',
	'https://images.unsplash.com/photo-1543512214-318228f18290?w=800&q=80',
	'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80',
	'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=800&q=80',
];

const heroImage = 'https://images.unsplash.com/photo-1558002038-1055907df827?w=1400&q=80';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style>
			body { font-family: 'Inter', system-ui, sans-serif; }
			@keyframes gradient-shift {
				0%, 100% { background-position: 0% 50%; }
				50% { background-position: 100% 50%; }
			}
			@keyframes float-slow {
				0%, 100% { transform: translateY(0px) rotate(0deg); }
				50% { transform: translateY(-20px) rotate(3deg); }
			}
			@keyframes float-slower {
				0%, 100% { transform: translateY(0px) rotate(0deg); }
				50% { transform: translateY(-15px) rotate(-2deg); }
			}
			@keyframes pulse-glow {
				0%, 100% { opacity: 0.4; transform: scale(1); }
				50% { opacity: 0.7; transform: scale(1.05); }
			}
			.animate-gradient-text {
				background: linear-gradient(135deg, #2563eb, #7c3aed, #2563eb, #06b6d4);
				background-size: 300% 300%;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				animation: gradient-shift 6s ease infinite;
			}
			.animate-float-slow { animation: float-slow 8s ease-in-out infinite; }
			.animate-float-slower { animation: float-slower 10s ease-in-out infinite; }
			.animate-pulse-glow { animation: pulse-glow 4s ease-in-out infinite; }
			.hero-mesh {
				background:
					radial-gradient(ellipse at 20% 50%, rgba(37, 99, 235, 0.15) 0%, transparent 50%),
					radial-gradient(ellipse at 80% 20%, rgba(124, 58, 237, 0.1) 0%, transparent 50%),
					radial-gradient(ellipse at 60% 80%, rgba(6, 182, 212, 0.08) 0%, transparent 50%),
					linear-gradient(135deg, #f8fafc 0%, #eef2ff 50%, #f0f9ff 100%);
				background-size: 200% 200%;
				animation: gradient-shift 12s ease infinite;
			}
			.glass-card {
				background: rgba(255, 255, 255, 0.6);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.3);
			}
			.glass-dark {
				background: rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.1);
			}
		</style>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"url": "https://smarthomemade.com"
		})} />
	</head>
	<body class="bg-white text-gray-900 antialiased">

		<!-- Thin top accent bar -->
		<div class="h-1 bg-gradient-to-r from-blue-600 via-violet-500 to-cyan-500"></div>

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100/80 shadow-sm">
			<div class="max-w-7xl mx-auto px-6 lg:px-10 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight">Smart<span class="text-blue-600">Home</span>Made</a>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-500">
					<a href="/" class="text-blue-600 font-semibold">Home</a>
					<a href="/blog" class="hover:text-blue-600 transition-colors duration-200">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition-colors duration-200">About</a>
				</div>
				<a href="/blog" class="hidden md:inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-blue-700 transition-all duration-200 hover:shadow-lg hover:shadow-blue-600/25">
					Read Guides
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
				</a>
				<!-- Mobile nav -->
				<div class="md:hidden flex items-center gap-4 text-sm font-medium text-gray-500">
					<a href="/blog" class="hover:text-blue-600 transition">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- ═══════════════ HERO ═══════════════ -->
			<section class="hero-mesh relative overflow-hidden">
				<!-- Floating decorative elements -->
				<div class="absolute top-20 left-10 w-72 h-72 bg-blue-400/20 rounded-full blur-3xl animate-pulse-glow"></div>
				<div class="absolute bottom-10 right-10 w-96 h-96 bg-violet-400/15 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 2s;"></div>
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-cyan-400/10 rounded-full blur-3xl animate-pulse-glow" style="animation-delay: 1s;"></div>

				<!-- Grid pattern overlay -->
				<div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #1e293b 1px, transparent 1px); background-size: 32px 32px;"></div>

				<div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-24 md:pt-24 md:pb-32">
					<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
						<!-- Left: Text -->
						<div>
							<div class="inline-flex items-center gap-2 bg-blue-100/80 text-blue-700 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6">
								<span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
								Smart Home Experts
							</div>
							<h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-[1.1] tracking-tight mb-6">
								Build a Smarter Home,
								<span class="animate-gradient-text block">The Right Way.</span>
							</h1>
							<p class="text-lg md:text-xl text-gray-500 leading-relaxed max-w-lg mb-8">
								No-BS reviews, practical guides, and honest recommendations from people who actually test this stuff.
							</p>
							<div class="flex flex-wrap gap-4">
								<a href="/blog" class="inline-flex items-center gap-2 bg-blue-600 text-white px-7 py-3.5 rounded-full font-bold text-sm hover:bg-blue-700 transition-all duration-300 hover:shadow-xl hover:shadow-blue-600/25 hover:-translate-y-0.5">
									Browse All Guides
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
								</a>
								<a href="/about" class="inline-flex items-center gap-2 bg-white text-gray-700 px-7 py-3.5 rounded-full font-bold text-sm border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition-all duration-300 hover:-translate-y-0.5">
									About Us
								</a>
							</div>
						</div>

						<!-- Right: Hero Image -->
						<div class="relative">
							<div class="animate-float-slow">
								<img
									src={heroImage}
									alt="Smart home living room with connected devices"
									class="rounded-3xl shadow-2xl shadow-blue-900/10 w-full object-cover aspect-[4/3]"
									loading="eager"
								/>
							</div>
							<!-- Floating badge -->
							<div class="absolute -bottom-4 -left-4 md:-bottom-6 md:-left-6 glass-card rounded-2xl p-4 shadow-xl animate-float-slower">
								<div class="flex items-center gap-3">
									<div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
										<svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
									</div>
									<div>
										<p class="text-sm font-bold text-gray-900">Independently Tested</p>
										<p class="text-xs text-gray-500">No sponsored reviews</p>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══════════════ STATS ═══════════════ -->
			<section class="border-y border-gray-100 bg-gray-50/50">
				<div class="max-w-7xl mx-auto px-6 lg:px-10 py-12">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
						{[
							{ value: '50+', label: 'Device Reviews', icon: '📱' },
							{ value: '12', label: 'Categories', icon: '📂' },
							{ value: '25K+', label: 'Monthly Readers', icon: '👥' },
							{ value: 'Weekly', label: 'New Content', icon: '✍️' },
						].map(stat => (
							<div class="text-center">
								<span class="text-2xl mb-2 block">{stat.icon}</span>
								<p class="text-2xl md:text-3xl font-black text-gray-900">{stat.value}</p>
								<p class="text-sm text-gray-500 font-medium mt-1">{stat.label}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ═══════════════ FEATURED ARTICLE ═══════════════ -->
			{featured && (
				<section class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-24">
					<div class="flex items-center gap-3 mb-10">
						<div class="h-px flex-1 bg-gray-200"></div>
						<span class="text-xs font-bold text-gray-400 uppercase tracking-widest">Featured Guide</span>
						<div class="h-px flex-1 bg-gray-200"></div>
					</div>

					<a href={`/blog/${featured.id}/`} class="group block">
						<div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
							<div class="relative overflow-hidden rounded-2xl">
								<img
									src={articleImages[0]}
									alt={featured.data.title}
									class="w-full aspect-[16/10] object-cover transition-transform duration-700 group-hover:scale-105"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
								<div class="absolute top-4 left-4">
									<span class="bg-blue-600 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Featured</span>
								</div>
							</div>
							<div>
								<p class="text-sm text-blue-600 font-semibold uppercase tracking-wider mb-3">
									{new Date(featured.data.pubDate).toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
								</p>
								<h2 class="text-2xl md:text-4xl font-black leading-tight mb-4 group-hover:text-blue-600 transition-colors duration-300">{featured.data.title}</h2>
								<p class="text-gray-500 text-lg leading-relaxed mb-6 line-clamp-3">{featured.data.description}</p>
								<span class="inline-flex items-center gap-2 text-blue-600 font-bold text-sm group-hover:gap-3 transition-all duration-300">
									Read Full Guide
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
								</span>
							</div>
						</div>
					</a>
				</section>
			)}

			<!-- ═══════════════ ARTICLE GRID ═══════════════ -->
			{rest.length > 0 && (
				<section class="bg-gray-50">
					<div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-24">
						<div class="flex items-center justify-between mb-10">
							<div>
								<h2 class="text-2xl md:text-3xl font-black">Latest Articles</h2>
								<p class="text-gray-500 mt-2">Fresh guides and reviews, published weekly.</p>
							</div>
							<a href="/blog" class="hidden md:inline-flex items-center gap-2 text-blue-600 font-semibold text-sm hover:gap-3 transition-all duration-300">
								View all
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
							</a>
						</div>

						<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
							{rest.map((post, i) => (
								<a href={`/blog/${post.id}/`} class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100 hover:border-blue-200 transition-all duration-500 hover:-translate-y-1.5">
									<div class="relative overflow-hidden">
										<img
											src={articleImages[(i + 1) % articleImages.length]}
											alt={post.data.title}
											class="w-full aspect-[16/10] object-cover transition-transform duration-700 group-hover:scale-105"
											loading="lazy"
										/>
										<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
									</div>
									<div class="p-6">
										<div class="flex items-center gap-3 mb-3">
											<span class="bg-blue-50 text-blue-600 px-2.5 py-0.5 rounded-full text-xs font-bold">Guide</span>
											<span class="text-xs text-gray-400 font-medium">
												{new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'short', day: 'numeric', year: 'numeric' })}
											</span>
										</div>
										<h3 class="text-lg font-bold leading-snug group-hover:text-blue-600 transition-colors duration-300 mb-2">{post.data.title}</h3>
										<p class="text-gray-500 text-sm leading-relaxed line-clamp-2">{post.data.description}</p>
										<span class="inline-flex items-center gap-1.5 text-blue-600 font-semibold text-sm mt-4 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
											Read more
											<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
										</span>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}

			<!-- ═══════════════ CATEGORIES ═══════════════ -->
			<section class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-24">
				<div class="text-center mb-12">
					<h2 class="text-2xl md:text-3xl font-black">Browse by Category</h2>
					<p class="text-gray-500 mt-2">Find exactly what you're looking for.</p>
				</div>
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
					{[
						{ icon: '🔌', name: 'Smart Plugs' },
						{ icon: '💡', name: 'Lighting' },
						{ icon: '🗣️', name: 'Voice Control' },
						{ icon: '📷', name: 'Security' },
						{ icon: '🌡️', name: 'Climate' },
						{ icon: '🚀', name: 'Getting Started' },
					].map(t => (
						<div class="group relative bg-white border border-gray-100 hover:border-blue-200 rounded-2xl p-6 cursor-default transition-all duration-300 hover:shadow-lg hover:-translate-y-1 text-center overflow-hidden">
							<div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-indigo-50 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
							<div class="relative">
								<span class="text-3xl mb-3 block">{t.icon}</span>
								<span class="text-sm font-bold text-gray-700 group-hover:text-blue-700 transition-colors duration-300">{t.name}</span>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- ═══════════════ NEWSLETTER CTA ═══════════════ -->
			<section class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800">
				<!-- Decorative -->
				<div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -mr-48 -mt-48"></div>
				<div class="absolute bottom-0 left-0 w-72 h-72 bg-white/5 rounded-full blur-3xl -ml-36 -mb-36"></div>

				<div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-20 md:py-28">
					<div class="max-w-2xl mx-auto text-center">
						<div class="glass-dark rounded-3xl p-10 md:p-14">
							<span class="text-blue-200 font-bold text-sm uppercase tracking-wider mb-4 block">Stay Updated</span>
							<h2 class="text-3xl md:text-4xl font-black text-white mb-4">Get Smart Home Tips, Weekly.</h2>
							<p class="text-blue-100/80 text-lg mb-8">Join thousands of readers who get our best guides and reviews delivered straight to their inbox. No spam, ever.</p>
							<div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
								<input
									type="email"
									placeholder="you@example.com"
									class="flex-1 px-5 py-3.5 rounded-full bg-white/10 border border-white/20 text-white placeholder-blue-200/60 text-sm focus:outline-none focus:ring-2 focus:ring-white/30"
								/>
								<button class="bg-white text-blue-700 px-7 py-3.5 rounded-full font-bold text-sm hover:bg-blue-50 transition-all duration-200 hover:shadow-lg whitespace-nowrap">
									Subscribe
								</button>
							</div>
							<p class="text-blue-200/50 text-xs mt-4">Free forever. Unsubscribe anytime.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- ═══════════════ ABOUT BLURB ═══════════════ -->
			<section class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-24">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<span class="text-blue-600 font-bold text-sm uppercase tracking-wider mb-4 block">Why SmartHomeMade?</span>
						<h2 class="text-3xl md:text-4xl font-black mb-6">No BS smart home advice.</h2>
						<p class="text-gray-500 text-lg leading-relaxed mb-6">We test the gadgets so you don't waste money on the wrong ones. Honest reviews, practical guides, and real recommendations from people who actually use this stuff every day.</p>
						<div class="flex flex-wrap gap-4">
							{['Independent Testing', 'No Sponsored Content', 'Real-World Usage'].map(item => (
								<div class="flex items-center gap-2 text-sm text-gray-600">
									<svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
									{item}
								</div>
							))}
						</div>
					</div>
					<div class="relative">
						<img
							src="https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=800&q=80"
							alt="Smart home setup with devices"
							class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]"
							loading="lazy"
						/>
					</div>
				</div>
			</section>
		</main>

		<!-- ═══════════════ FOOTER ═══════════════ -->
		<footer class="bg-gray-950 text-gray-400">
			<div class="max-w-7xl mx-auto px-6 lg:px-10 py-16">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
					<div class="col-span-2 md:col-span-1">
						<a href="/" class="text-xl font-black text-white">Smart<span class="text-blue-400">Home</span>Made</a>
						<p class="text-sm text-gray-500 mt-3 leading-relaxed">Honest smart home reviews and guides. No sponsored content, no BS.</p>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Content</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">All Articles</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Reviews</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Buying Guides</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">How-To Guides</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Categories</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Smart Plugs</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Voice Assistants</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Lighting</a></li>
