---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featured = posts[0];
const recent = posts.slice(1, 5);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			@keyframes fade-up {
				from { opacity: 0; transform: translateY(24px); }
				to { opacity: 1; transform: translateY(0); }
			}
			@keyframes fade-in {
				from { opacity: 0; }
				to { opacity: 1; }
			}
			.animate-fade-up { animation: fade-up 0.7s ease-out both; }
			.animate-fade-in { animation: fade-in 0.8s ease-out both; }
			.delay-100 { animation-delay: 0.1s; }
			.delay-200 { animation-delay: 0.2s; }
			.delay-300 { animation-delay: 0.3s; }
			.delay-400 { animation-delay: 0.4s; }
		</style>
	</head>
	<body class="bg-gray-50 text-gray-800 antialiased overflow-x-hidden">
		<!-- Glassmorphism Nav -->
		<nav class="sticky top-0 z-50 bg-white/70 backdrop-blur-xl border-b border-white/20 shadow-sm">
			<div class="max-w-7xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight text-gray-900 hover:opacity-80 transition-opacity">
					Smart<span class="text-blue-600">Home</span>Made
				</a>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-blue-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="hover:text-blue-600 transition-colors duration-200">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition-colors duration-200">About</a>
				</div>
				<a href="/blog" class="hidden md:inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-blue-700 transition-all duration-200 shadow-md hover:shadow-lg hover:shadow-blue-600/25">
					Read Guides
					<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
				</a>
				<!-- Mobile menu button -->
				<div class="md:hidden flex items-center gap-4">
					<a href="/blog" class="text-sm font-medium text-blue-600">Articles</a>
					<a href="/about" class="text-sm font-medium text-gray-500">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- Hero -->
			<section class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-900 text-white">
				<!-- Decorative elements -->
				<div class="absolute inset-0 overflow-hidden">
					<div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl"></div>
					<div class="absolute -bottom-40 -left-40 w-96 h-96 bg-indigo-500/20 rounded-full blur-3xl"></div>
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-blue-400/5 rounded-full blur-3xl"></div>
					<!-- Grid pattern -->
					<div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
				</div>
				<div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-24 md:py-32 lg:py-40">
					<div class="max-w-3xl">
						<span class="animate-fade-up inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm font-medium mb-8 backdrop-blur-sm border border-white/10">
							<span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
							Your trusted smart home guide
						</span>
						<h1 class="animate-fade-up delay-100 text-4xl md:text-6xl lg:text-7xl font-black leading-[0.95] tracking-tight mb-8">
							Build a Smarter<br>Home, <span class="bg-gradient-to-r from-blue-200 to-cyan-200 bg-clip-text text-transparent">The Right Way</span>
						</h1>
						<p class="animate-fade-up delay-200 text-lg md:text-xl text-blue-100/90 leading-relaxed mb-10 max-w-xl">
							Honest reviews, practical guides, and no-BS advice. We test the gadgets so you don't waste money on the wrong ones.
						</p>
						<div class="animate-fade-up delay-300 flex flex-wrap gap-4">
							<a href="/blog" class="inline-flex items-center gap-2 bg-white text-blue-700 px-7 py-3.5 rounded-full font-bold text-sm hover:bg-blue-50 transition-all duration-300 shadow-xl shadow-black/10 hover:shadow-2xl hover:scale-[1.02]">
								Read Our Guides
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
							</a>
							<a href="/about" class="inline-flex items-center gap-2 bg-white/10 text-white px-7 py-3.5 rounded-full font-bold text-sm hover:bg-white/20 transition-all duration-300 backdrop-blur-sm border border-white/20">
								Learn More
							</a>
						</div>
					</div>
				</div>
				<!-- Bottom fade -->
				<div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-50 to-transparent"></div>
			</section>

			<!-- Featured Post (overlapping hero) -->
			{featured && (
				<section class="max-w-7xl mx-auto px-6 lg:px-8 -mt-16 relative z-10 mb-20">
					<a href={`/blog/${featured.id}/`} class="group block bg-white rounded-3xl shadow-2xl shadow-gray-900/10 hover:shadow-3xl transition-all duration-500 p-8 md:p-12 border border-gray-100 hover:border-blue-100 hover:-translate-y-1">
						<div class="flex flex-col md:flex-row md:items-center gap-6">
							<div class="flex-1">
								<div class="flex items-center gap-3 mb-5">
									<span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 bg-blue-600 text-white rounded-full text-xs font-bold uppercase tracking-wider">
										<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
										Featured
									</span>
									<span class="text-xs text-gray-400 font-medium">
										{new Date(featured.data.pubDate).toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
									</span>
								</div>
								<h2 class="text-2xl md:text-4xl font-black text-gray-900 mb-4 group-hover:text-blue-600 transition-colors duration-300 leading-tight">{featured.data.title}</h2>
								<p class="text-gray-500 leading-relaxed mb-6 max-w-2xl text-base md:text-lg">{featured.data.description}</p>
								<span class="inline-flex items-center gap-2 text-blue-600 font-bold text-sm group-hover:gap-3 transition-all duration-300">
									Read the full article
									<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
								</span>
							</div>
						</div>
					</a>
				</section>
			)}

			<!-- Latest Articles -->
			<section class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
				<div class="flex items-end justify-between mb-12">
					<div>
						<span class="text-blue-600 font-bold text-sm uppercase tracking-wider mb-2 block">Stay Updated</span>
						<h2 class="text-3xl md:text-4xl font-black text-gray-900">Latest Articles</h2>
					</div>
					<a href="/blog" class="hidden md:inline-flex items-center gap-2 text-blue-600 font-semibold text-sm hover:gap-3 transition-all duration-300">
						View all articles
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
					</a>
				</div>
				<div class="grid md:grid-cols-2 gap-6 lg:gap-8">
					{recent.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="group relative block bg-white rounded-2xl p-7 md:p-8 border border-gray-100 hover:border-blue-200 shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1 overflow-hidden">
							<div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-blue-600 to-indigo-600 rounded-l-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
							<p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-3">
								{new Date(post.data.pubDate).toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
							</p>
							<h3 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors duration-300 mb-3 leading-snug">{post.data.title}</h3>
							<p class="text-gray-500 text-sm leading-relaxed mb-4">{post.data.description}</p>
							<span class="inline-flex items-center gap-1.5 text-blue-600 font-semibold text-sm opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
								Read more
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
							</span>
						</a>
					))}
				</div>
				<div class="mt-8 text-center md:hidden">
					<a href="/blog" class="inline-flex items-center gap-2 text-blue-600 font-semibold text-sm">
						View all articles →
					</a>
				</div>
			</section>

			<!-- Topics / Categories -->
			<section class="bg-white border-y border-gray-100">
				<div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
					<div class="text-center mb-14">
						<span class="text-blue-600 font-bold text-sm uppercase tracking-wider mb-2 block">Explore Topics</span>
						<h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4">What We Cover</h2>
						<p class="text-gray-500 max-w-lg mx-auto">From smart plugs to full home automation — we've got guides for every step of your smart home journey.</p>
					</div>
					<div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
						{[
							{ icon: '🔌', title: 'Smart Plugs', desc: 'Make any device smart' },
							{ icon: '💡', title: 'Smart Lighting', desc: 'Bulbs, strips & switches' },
							{ icon: '🗣️', title: 'Voice Assistants', desc: 'Alexa vs Google vs Siri' },
							{ icon: '🔒', title: 'Security', desc: 'Cameras, locks & sensors' },
							{ icon: '🌡️', title: 'Climate', desc: 'Thermostats & comfort' },
							{ icon: '🏠', title: 'Getting Started', desc: 'New? Start here' },
						].map(cat => (
							<div class="group bg-gray-50 rounded-2xl p-6 md:p-8 text-center hover:bg-blue-600 transition-all duration-500 cursor-default hover:shadow-xl hover:shadow-blue-600/20 hover:-translate-y-1">
								<span class="text-4xl mb-4 block group-hover:scale-110 transition-transform duration-300">{cat.icon}</span>
								<h3 class="font-bold text-gray-900 group-hover:text-white transition-colors duration-300 text-sm md:text-base">{cat.title}</h3>
								<p class="text-gray-400 group-hover:text-blue-100 text-xs md:text-sm mt-2 transition-colors duration-300">{cat.desc}</p>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Newsletter -->
			<section class="relative overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800"></div>
				<div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:32px_32px]"></div>
				<div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
					<div class="max-w-2xl mx-auto text-center">
						<span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 rounded-full text-sm font-medium text-white mb-6 backdrop-blur-sm border border-white/10">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
							Newsletter
						</span>
						<h2 class="text-3xl md:text-4xl font-black text-white mb-4">Stay in the Loop</h2>
						<p class="text-blue-100/80 mb-8 text-base md:text-lg">Get the latest smart home reviews, guides, and deals delivered straight to your inbox. No spam, ever.</p>
						<div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
							<input type="email" placeholder="Enter your email" class="flex-1 px-5 py-3.5 rounded-full bg-white/10 border border-white/20 text-white placeholder-blue-200/60 focus:outline-none focus:ring-2 focus:ring-white/30 backdrop-blur-sm text-sm" />
							<button class="px-7 py-3.5 bg-white text-blue-700 rounded-full font-bold text-sm hover:bg-blue-50 transition-all duration-300 shadow-lg hover:shadow-xl whitespace-nowrap">
								Subscribe
							</button>
						</div>
						<p class="text-blue-200/50 text-xs mt-4">Free forever. Unsubscribe anytime.</p>
					</div>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-950 text-gray-400">
			<div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-20">
				<div class="grid md:grid-cols-3 gap-12 md:gap-8 mb-12">
					<div>
						<p class="text-white font-black text-2xl mb-3">Smart<span class="text-blue-400">Home</span>Made</p>
						<p class="text-sm leading-relaxed text-gray-500 max-w-xs">Honest smart home reviews and guides. Helping you build a connected home without the headaches.</p>
					</div>
					<div>
						<h4 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Quick Links</h4>
						<div class="flex flex-col gap-3">
							<a href="/" class="text-sm hover:text-white transition-colors duration-200">Home</a>
							<a href="/blog" class="text-sm hover:text-white transition-colors duration-200">Articles</a>
							<a href="/about" class="text-sm hover:text-white transition-colors duration-200">About</a>
						</div>
					</div>
					<div>
						<h4 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Topics</h4>
						<div class="flex flex-col gap-3">
							<span class="text-sm">Smart Lighting</span>
							<span class="text-sm">Voice Assistants</span>
							<span class="text-sm">Home Security</span>
						</div>
					</div>
				</div>
				<div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
					<p class="text-xs text-gray-600">&copy; 2026 SmartHomeMade. All rights reserved.</p>
					<div class="flex gap-6">
						<a href="#" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Privacy</a>
						<a href="#" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Terms</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>
