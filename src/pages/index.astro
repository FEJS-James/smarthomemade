---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style>body{font-family:'Inter',system-ui,sans-serif}</style>
	</head>
	<body class="bg-white text-gray-900 antialiased">
		<!-- Thin top accent -->
		<div class="h-1 bg-gradient-to-r from-blue-600 via-indigo-500 to-violet-500"></div>

		<!-- Nav — minimal, editorial -->
		<nav class="max-w-7xl mx-auto px-6 lg:px-10 py-6 flex items-center justify-between">
			<a href="/" class="text-2xl font-black tracking-tight">Smart<span class="text-blue-600">Home</span>Made</a>
			<div class="flex items-center gap-8 text-sm text-gray-500 font-medium">
				<a href="/blog" class="hover:text-gray-900 transition">Guides</a>
				<a href="/about" class="hover:text-gray-900 transition">About</a>
			</div>
		</nav>

		<main>
			<!-- Hero — asymmetric split -->
			{featured && (
				<section class="max-w-7xl mx-auto px-6 lg:px-10 pt-8 pb-20">
					<div class="grid lg:grid-cols-5 gap-12 items-start">
						<!-- Left: big featured story -->
						<div class="lg:col-span-3">
							<a href={`/blog/${featured.id}/`} class="group block">
								<div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-3xl p-10 lg:p-14 relative overflow-hidden">
									<div class="absolute top-0 right-0 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-50 -mr-20 -mt-20"></div>
									<div class="relative">
										<span class="text-xs font-bold text-blue-600 uppercase tracking-widest">Featured Guide</span>
										<h1 class="text-3xl lg:text-5xl font-black leading-tight mt-4 mb-6 group-hover:text-blue-700 transition">{featured.data.title}</h1>
										<p class="text-gray-500 text-lg leading-relaxed max-w-xl mb-8">{featured.data.description}</p>
										<div class="flex items-center gap-4">
											<span class="bg-blue-600 text-white px-5 py-2.5 rounded-full text-sm font-semibold group-hover:bg-blue-700 transition">Read Guide</span>
											<span class="text-sm text-gray-400">
												{new Date(featured.data.pubDate).toLocaleDateString('en-us', { month: 'long', day: 'numeric', year: 'numeric' })}
											</span>
										</div>
									</div>
								</div>
							</a>
						</div>

						<!-- Right: vertical stack of other articles -->
						<div class="lg:col-span-2 flex flex-col gap-6">
							<h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest">Latest</h2>
							{rest.map((post) => (
								<a href={`/blog/${post.id}/`} class="group block pb-6 border-b border-gray-100 last:border-0">
									<p class="text-xs text-gray-400 mb-1">
										{new Date(post.data.pubDate).toLocaleDateString('en-us', { month: 'short', day: 'numeric' })}
									</p>
									<h3 class="text-lg font-bold leading-snug group-hover:text-blue-600 transition">{post.data.title}</h3>
									<p class="text-gray-500 text-sm mt-1 leading-relaxed line-clamp-2">{post.data.description}</p>
								</a>
							))}
						</div>
					</div>
				</section>
			)}

			<!-- Divider -->
			<div class="max-w-7xl mx-auto px-6 lg:px-10"><div class="h-px bg-gray-100"></div></div>

			<!-- Topics — horizontal scroll -->
			<section class="max-w-7xl mx-auto px-6 lg:px-10 py-16">
				<h2 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-8">Browse by Topic</h2>
				<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
					{[
						{ icon: '🔌', name: 'Smart Plugs' },
						{ icon: '💡', name: 'Lighting' },
						{ icon: '🗣️', name: 'Voice Control' },
						{ icon: '📷', name: 'Security' },
						{ icon: '🌡️', name: 'Climate' },
						{ icon: '🚀', name: 'Getting Started' },
					].map(t => (
						<div class="group flex items-center gap-3 bg-gray-50 hover:bg-blue-50 rounded-xl px-5 py-4 cursor-default transition">
							<span class="text-xl">{t.icon}</span>
							<span class="text-sm font-semibold text-gray-700 group-hover:text-blue-700 transition">{t.name}</span>
						</div>
					))}
				</div>
			</section>

			<!-- About blurb -->
			<section class="bg-gray-950 text-white">
				<div class="max-w-7xl mx-auto px-6 lg:px-10 py-20 grid lg:grid-cols-2 gap-12 items-center">
					<div>
						<h2 class="text-3xl font-black mb-4">No BS smart home advice.</h2>
						<p class="text-gray-400 text-lg leading-relaxed">We test the gadgets so you don't waste money on the wrong ones. Honest reviews, practical guides, and real recommendations from people who actually use this stuff.</p>
					</div>
					<div class="flex justify-center lg:justify-end">
						<a href="/blog" class="bg-white text-gray-900 px-8 py-4 rounded-full font-bold text-lg hover:bg-gray-100 transition">Read All Guides →</a>
					</div>
				</div>
			</section>
		</main>

		<footer class="max-w-7xl mx-auto px-6 lg:px-10 py-10 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-400">
			<p>© 2026 SmartHomeMade</p>
			<div class="flex gap-6">
				<a href="/blog" class="hover:text-gray-900 transition">Guides</a>
				<a href="/about" class="hover:text-gray-900 transition">About</a>
			</div>
		</footer>
	</body>
</html>
