---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const articleImages = [
	'https://images.unsplash.com/photo-1558002038-1055907df827?w=800&q=80',
	'https://images.unsplash.com/photo-1556228578-0d85b1a4d571?w=800&q=80',
	'https://images.unsplash.com/photo-1543512214-318228f18290?w=800&q=80',
	'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&q=80',
	'https://images.unsplash.com/photo-1585771724684-38269d6639fd?w=800&q=80',
];

const categories = ['All', 'Reviews', 'Buying Guides', 'How-To', 'Comparisons', 'Getting Started'];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`All Articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
		<style>body { font-family: 'Inter', system-ui, sans-serif; }</style>
		<meta property="og:type" content="website" />
		<meta property="og:title" content={`All Articles — ${SITE_TITLE}`} />
		<meta property="og:description" content={SITE_DESCRIPTION} />
		<meta name="twitter:card" content="summary_large_image" />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
	</head>
	<body class="bg-white text-gray-900 antialiased">

		<!-- Top accent -->
		<div class="h-1 bg-gradient-to-r from-blue-600 via-violet-500 to-cyan-500"></div>

		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-xl border-b border-gray-100/80 shadow-sm">
			<div class="max-w-7xl mx-auto px-6 lg:px-10 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight">Smart<span class="text-blue-600">Home</span>Made</a>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-blue-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="text-blue-600 font-semibold">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition-colors duration-200">About</a>
				</div>
				<div class="md:hidden flex items-center gap-4 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-blue-600 transition">Home</a>
					<a href="/about" class="hover:text-blue-600 transition">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- Page Header -->
			<section class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-blue-900 to-indigo-900 text-white">
				<div class="absolute inset-0 opacity-[0.05]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>
				<div class="absolute top-0 right-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl -mr-48 -mt-48"></div>

				<div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-24">
					<div class="inline-flex items-center gap-2 bg-white/10 text-blue-200 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6 backdrop-blur-sm border border-white/10">
						<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
						{posts.length} Articles
					</div>
					<h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">All Articles</h1>
					<p class="text-blue-100/70 text-lg max-w-xl">Reviews, guides, and tutorials to help you build the perfect smart home.</p>
				</div>
			</section>

			<!-- Category pills -->
			<section class="border-b border-gray-100 bg-gray-50/50">
				<div class="max-w-7xl mx-auto px-6 lg:px-10 py-4">
					<div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-hide">
						{categories.map((cat, i) => (
							<button class={`px-4 py-2 rounded-full text-sm font-semibold whitespace-nowrap transition-all duration-200 ${i === 0 ? 'bg-blue-600 text-white shadow-sm' : 'bg-white text-gray-500 border border-gray-200 hover:border-blue-300 hover:text-blue-600'}`}>
								{cat}
							</button>
						))}
					</div>
				</div>
			</section>

			<!-- Posts Grid -->
			<section class="max-w-7xl mx-auto px-6 lg:px-10 py-16 md:py-20">
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{posts.map((post, i) => (
						<a href={`/blog/${post.id}/`} class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-gray-100 hover:border-blue-200 transition-all duration-500 hover:-translate-y-1.5">
							<div class="relative overflow-hidden">
								<img
									src={articleImages[i % articleImages.length]}
									alt={post.data.title}
									class="w-full aspect-[16/10] object-cover transition-transform duration-700 group-hover:scale-105"
									loading="lazy"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
							</div>
							<div class="p-6">
								<div class="flex items-center gap-3 mb-3">
									<span class="bg-blue-50 text-blue-600 px-2.5 py-0.5 rounded-full text-xs font-bold">Guide</span>
									<span class="text-xs text-gray-400 font-medium">
										{new Date(post.data.pubDate).toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
									</span>
								</div>
								<h2 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors duration-300 mb-2 leading-snug">{post.data.title}</h2>
								<p class="text-gray-500 text-sm leading-relaxed line-clamp-2 mb-4">{post.data.description}</p>
								<span class="inline-flex items-center gap-1.5 text-blue-600 font-semibold text-sm opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
									Read article
									<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
								</span>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- Newsletter CTA -->
			<section class="bg-gray-50 border-t border-gray-100">
				<div class="max-w-3xl mx-auto px-6 lg:px-10 py-16 text-center">
					<h2 class="text-2xl md:text-3xl font-black mb-3">Never miss a guide.</h2>
					<p class="text-gray-500 mb-8">Get our best articles delivered to your inbox, weekly.</p>
					<div class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
						<input type="email" placeholder="you@example.com" class="flex-1 px-5 py-3 rounded-full border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/30 focus:border-blue-400" />
						<button class="bg-blue-600 text-white px-7 py-3 rounded-full font-bold text-sm hover:bg-blue-700 transition-all duration-200 whitespace-nowrap">Subscribe</button>
					</div>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-950 text-gray-400">
			<div class="max-w-7xl mx-auto px-6 lg:px-10 py-16">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
					<div class="col-span-2 md:col-span-1">
						<a href="/" class="text-xl font-black text-white">Smart<span class="text-blue-400">Home</span>Made</a>
						<p class="text-sm text-gray-500 mt-3 leading-relaxed">Honest smart home reviews and guides. No sponsored content, no BS.</p>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Content</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">All Articles</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Reviews</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Buying Guides</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">Categories</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Smart Plugs</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Voice Assistants</a></li>
							<li><a href="/blog" class="hover:text-white transition-colors duration-200">Lighting</a></li>
						</ul>
					</div>
					<div>
						<h3 class="text-white font-bold text-sm uppercase tracking-wider mb-4">About</h3>
						<ul class="space-y-2.5 text-sm">
							<li><a href="/about" class="hover:text-white transition-colors duration-200">About Us</a></li>
							<li><a href={new URL('rss.xml', Astro.site).href} class="hover:text-white transition-colors duration-200">RSS Feed</a></li>
						</ul>
					</div>
				</div>
				<div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
					<p class="text-xs text-gray-600">&copy; 2026 SmartHomeMade. All rights reserved.</p>
					<p class="text-xs text-gray-600">Made with care for smart home enthusiasts.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
