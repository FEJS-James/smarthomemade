---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<BaseHead title={`Articles — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-50 text-gray-800 antialiased">
		<!-- Nav -->
		<nav class="sticky top-0 z-50 bg-white/70 backdrop-blur-xl border-b border-white/20 shadow-sm">
			<div class="max-w-7xl mx-auto px-6 lg:px-8 py-4 flex items-center justify-between">
				<a href="/" class="text-2xl font-black tracking-tight text-gray-900 hover:opacity-80 transition-opacity">
					Smart<span class="text-blue-600">Home</span>Made
				</a>
				<div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-500">
					<a href="/" class="hover:text-blue-600 transition-colors duration-200">Home</a>
					<a href="/blog" class="text-blue-600 font-semibold">Articles</a>
					<a href="/about" class="hover:text-blue-600 transition-colors duration-200">About</a>
				</div>
				<div class="md:hidden flex items-center gap-4">
					<a href="/" class="text-sm font-medium text-gray-500">Home</a>
					<a href="/about" class="text-sm font-medium text-gray-500">About</a>
				</div>
			</div>
		</nav>

		<main>
			<!-- Page Header -->
			<section class="bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-900 text-white">
				<div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
					<span class="text-blue-200 font-bold text-sm uppercase tracking-wider mb-2 block">Our Blog</span>
					<h1 class="text-3xl md:text-5xl font-black tracking-tight mb-4">All Articles</h1>
					<p class="text-blue-100/80 text-lg max-w-xl">Reviews, guides, and tutorials to help you build the perfect smart home.</p>
				</div>
			</section>

			<!-- Posts Grid -->
			<section class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-20">
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="group relative block bg-white rounded-2xl p-7 border border-gray-100 hover:border-blue-200 shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1 overflow-hidden">
							<div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-blue-600 to-indigo-600 rounded-l-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
							<p class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-3">
								{new Date(post.data.pubDate).toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
							</p>
							<h2 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors duration-300 mb-3 leading-snug">{post.data.title}</h2>
							<p class="text-gray-500 text-sm leading-relaxed mb-4">{post.data.description}</p>
							<span class="inline-flex items-center gap-1.5 text-blue-600 font-semibold text-sm opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
								Read article
								<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
							</span>
						</a>
					))}
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="bg-gray-950 text-gray-400">
			<div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
				<div class="flex flex-col md:flex-row items-center justify-between gap-4">
					<p class="text-white font-black text-lg">Smart<span class="text-blue-400">Home</span>Made</p>
					<p class="text-xs text-gray-600">&copy; 2026 SmartHomeMade. All rights reserved.</p>
				</div>
			</div>
		</footer>
	</body>
</html>
